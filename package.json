{
  "name": "cryo-protocol",
  "type": "module",
  "scripts": {
    "build-web": "tsc -p tsconfig.web.json",
    "build-node": "tsc -p tsconfig.node.json",
    "build": "npm run build-node && npm run build-web",
    "prepack": "npm run build"
  },
  "exports": {
    ".": {
      "types": "./dist/node/index.node.d.ts",
      "browser": "./dist/web/index.web.js",
      "node": "./dist/node/index.node.js",
      "default": "./dist/node/index.node.js"
    }
  },
  "types": "./dist/node/index.node.d.ts",
  "version": "1.1.7",
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.0",
    "chai": "^6.2.2"
  },
  "dependencies": {
    "mocha": "^7.2.0"
  }
}
